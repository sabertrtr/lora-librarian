# lora-librarian server config. Copy to `.env` and fill in.
# .env is gitignored -- SECRETS live here, never in source.

# ---- secrets (required) ----------------------------------------------------
# Your Civitai API token (Account -> Settings -> API Keys). Used server-side to
# resolve/download models and to include NSFW-inclusive search results.
CIVITAI_TOKEN=

# Shared secret the browser extension / web pages must present. Generate a random
# one, e.g.:  node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# Put this SAME value into the extension's options page ("Service token").
SERVICE_TOKEN=

# ---- network ---------------------------------------------------------------
# Port to listen on.
PORT=8420
# Bind address. 0.0.0.0 = reachable from other machines on the LAN.
# 127.0.0.1 = loopback only (single-machine install; pair with the extension
# pointed at https://localhost:PORT or http://127.0.0.1:PORT).
HOST=0.0.0.0

# ---- TLS (optional; required for the extension unless using loopback) -------
# The Firefox extension's background page is a secure context and upgrades http
# fetches to https, EXCEPT for loopback (localhost / 127.0.0.1). So: a LAN/remote
# server needs a cert here; a single-machine loopback server can run plain HTTP.
# Defaults to ./certs/{key,cert}.pem if present.
# TLS_KEY=./certs/key.pem
# TLS_CERT=./certs/cert.pem

# ---- data locations (optional; sensible defaults) --------------------------
# Directory holding library.yaml (+ generated staging.json / civitai_cache.json).
WILDCARDS_DIR=./data
# Where accepted LoRAs are downloaded (should be your Forge/A1111 loras folder).
DOWNLOAD_DIR=./downloads
# Overrides (default under WILDCARDS_DIR):
# STAGING_FILE=./data/staging.json
# CIVITAI_CACHE_FILE=./data/civitai_cache.json
